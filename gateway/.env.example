# PiGlot Gateway Environment Variables
# Copy to .env and fill in your keys

# Admin token (required for device management)
PIGLOT_ADMIN_TOKEN=change-me-to-a-secure-random-string

# LLM Providers (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# TTS (optional — Edge TTS is free and needs no key)
ELEVENLABS_API_KEY=

# Spotify (optional)
SPOTIFY_ACCESS_TOKEN=
